# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Mapbox API token — used for both Forward Geocoding and Directions API.
# Get yours at https://account.mapbox.com/
MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Path to the fuel-price CSV (relative to manage.py or absolute).
FUEL_CSV_PATH=data/fuel_prices.csv

# SQLite file that caches geocoded (city, state) → (lat, lon) results.
# Avoids re-geocoding on every restart.  Safe to delete to force a refresh.
GEOCODE_CACHE_PATH=geocode_cache.db

# Django secret key — generate a fresh one for production.
DJANGO_SECRET_KEY=change-me-in-production

# Set to False in production.
DJANGO_DEBUG=True

# Comma-separated hostnames for Django when DJANGO_DEBUG=False.
# Example: routeopt-api.onrender.com
ALLOWED_HOSTS=

# Comma-separated frontend origins allowed by CORS in production.
# Example: https://routeopt.vercel.app
CORS_ALLOWED_ORIGINS=

# Optional comma-separated regexes for preview deployments.
# Example: ^https://routeopt-.*\.vercel\.app$
CORS_ALLOWED_ORIGIN_REGEXES=

# Max miles a vehicle can travel off-route to a fuel station.
MAX_OFF_ROUTE_MILES=5.0

# Snap route coordinates every N miles when projecting stations.
# Lower = more accurate, higher = faster startup projection.
ROUTE_SAMPLE_INTERVAL_MILES=1.0
